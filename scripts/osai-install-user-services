#!/bin/bash
# Install OSAI systemd user services
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

ENABLE_NOW=false
ENABLE_VLLM=false
ENABLE_LLAMACPP=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        --enable-now)
            ENABLE_NOW=true
            shift
            ;;
        --enable-vllm)
            ENABLE_VLLM=true
            shift
            ;;
        --enable-llamacpp)
            ENABLE_LLAMACPP=true
            shift
            ;;
        -h|--help)
            echo "Usage: $0 [--enable-now] [--enable-vllm] [--enable-llamacpp]"
            echo ""
            echo "Options:"
            echo "  --enable-now        Enable and start the service immediately"
            echo "  --enable-vllm       Also enable vLLM service (only with --enable-now)"
            echo "  --enable-llamacpp   Also enable llama.cpp service (only with --enable-now)"
            echo ""
            echo "This script installs systemd user units from:"
            echo "  ${REPO_ROOT}/systemd/user/"
            echo "to:"
            echo "  ~/.config/systemd/user/"
            exit 0
            ;;
        *)
            echo "Unknown option: $1" >&2
            exit 1
            ;;
    esac
done

if [[ "$ENABLE_VLLM" == "true" ]] && [[ "$ENABLE_NOW" != "true" ]]; then
    echo "Error: --enable-vllm requires --enable-now"
    exit 1
fi

if [[ "$ENABLE_LLAMACPP" == "true" ]] && [[ "$ENABLE_NOW" != "true" ]]; then
    echo "Error: --enable-llamacpp requires --enable-now"
    exit 1
fi

USER_SERVICE_DIR="${HOME}/.config/systemd/user"
SYSTEMD_SOURCE="${REPO_ROOT}/systemd/user"

echo "Installing OSAI systemd user services..."
echo ""

# Create user systemd directory if it doesn't exist
mkdir -p "$USER_SERVICE_DIR"

# Copy service files
for service_file in "${SYSTEMD_SOURCE}"/*.service; do
    if [[ -f "$service_file" ]]; then
        service_name=$(basename "$service_file")
        echo "  Copying $service_name..."
        cp "$service_file" "${USER_SERVICE_DIR}/"
    fi
done

echo ""
echo "Running systemctl --user daemon-reload..."
systemctl --user daemon-reload

echo ""
echo "=== Installation complete ==="
echo ""
echo "Installed services:"
echo "  - osai-model-router.service (API gateway)"
echo "  - osai-vllm.service (vLLM local runtime, optional)"
echo "  - osai-llamacpp.service (llama.cpp local runtime, optional)"
echo ""
echo "Next steps:"
echo ""

if [[ "$ENABLE_NOW" == "true" ]]; then
    echo "Enabling and starting osai-model-router.service..."
    systemctl --user enable --now osai-model-router.service
    echo ""
    echo "Service status:"
    systemctl --user status osai-model-router.service

    if [[ "$ENABLE_VLLM" == "true" ]]; then
        echo ""
        echo "Enabling and starting osai-vllm.service..."
        systemctl --user enable --now osai-vllm.service
        echo ""
        echo "vLLM service status:"
        systemctl --user status osai-vllm.service
    fi

    if [[ "$ENABLE_LLAMACPP" == "true" ]]; then
        echo ""
        echo "Enabling and starting osai-llamacpp.service..."
        systemctl --user enable --now osai-llamacpp.service
        echo ""
        echo "llama.cpp service status:"
        systemctl --user status osai-llamacpp.service
    fi
else
    echo "To start osai-model-router.service manually:"
    echo "  systemctl --user start osai-model-router.service"
    echo ""
    echo "To enable at login:"
    echo "  systemctl --user enable osai-model-router.service"
    echo ""
    echo "To check status:"
    echo "  systemctl --user status osai-model-router.service"
    echo ""
    echo "To view logs:"
    echo "  journalctl --user -u osai-model-router -f"
    echo ""
    echo "For llama.cpp runtime management:"
    echo "  ./scripts/osai-llamacpp-up   # Start llama.cpp"
    echo "  ./scripts/osai-llamacpp-check # Check health"
    echo "  ./scripts/osai-llamacpp-down  # Stop llama.cpp service"
    echo ""
    echo "For vLLM runtime management:"
    echo "  ./scripts/osai-vllm-up   # Start vLLM"
    echo "  ./scripts/osai-vllm-check # Check health"
    echo "  ./scripts/osai-vllm-down  # Stop vLLM service"
fi

exit 0
