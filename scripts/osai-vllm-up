#!/bin/bash
# OSAI vLLM Up - Start vLLM local runtime
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Load vLLM environment
source "${SCRIPT_DIR}/osai-vllm-env"

# Check if vLLM binary is available (repo-local or PATH)
if [[ ! -x "$OSAI_VLLM_BIN" ]] && ! command -v vllm &> /dev/null; then
    echo "Error: vLLM is not installed."
    echo ""
    echo "To install vLLM in the repo-local runtime directory:"
    echo "  mkdir -p .local-runtimes/vllm"
    echo "  python3 -m venv .local-runtimes/vllm/.venv"
    echo "  source .local-runtimes/vllm/.venv/bin/activate"
    echo "  python -m pip install --upgrade pip setuptools wheel"
    echo "  python -m pip install vllm"
    echo ""
    echo "Then run this script again."
    exit 1
fi

# Use OSAI_VLLM_BIN if set and executable, otherwise fall back to vllm from PATH
VLLM_CMD="${OSAI_VLLM_BIN}"
if [[ ! -x "$VLLM_CMD" ]]; then
    VLLM_CMD="vllm"
fi

echo "Starting vLLM local runtime..."
echo "  Model: ${OSAI_VLLM_MODEL}"
echo "  Host: ${OSAI_VLLM_HOST}"
echo "  Port: ${OSAI_VLLM_PORT}"
echo "  Base URL: ${OSAI_VLLM_BASE_URL}"
echo ""
echo "Press Ctrl+C to stop"
echo ""

exec "$VLLM_CMD" serve "$OSAI_VLLM_MODEL" \
    --host "$OSAI_VLLM_HOST" \
    --port "$OSAI_VLLM_PORT" \
    --api-key "$OSAI_VLLM_API_KEY" \
    $OSAI_VLLM_EXTRA_ARGS
