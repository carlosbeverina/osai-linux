#!/bin/bash
# OSAI Local Runtime Up - Start llama.cpp and Model Router together
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# shellcheck disable=SC1091
source "${SCRIPT_DIR}/osai-local-env"

LLAMACPP_PID=""
ROUTER_PID=""
ROUTER_VENV="${REPO_ROOT}/services/model-router/.venv"

cleanup() {
    echo ""
    echo "=== Stopping services ==="
    if [[ -n "$LLAMACPP_PID" ]] && kill -0 "$LLAMACPP_PID" 2>/dev/null; then
        echo "Stopping llama-server (PID $LLAMACPP_PID)..."
        kill "$LLAMACPP_PID" 2>/dev/null || true
        wait "$LLAMACPP_PID" 2>/dev/null || true
    fi
    if [[ -n "$ROUTER_PID" ]] && kill -0 "$ROUTER_PID" 2>/dev/null; then
        echo "Stopping Model Router (PID $ROUTER_PID)..."
        kill "$ROUTER_PID" 2>/dev/null || true
        wait "$ROUTER_PID" 2>/dev/null || true
    fi
    echo "Done."
    exit 0
}

trap cleanup SIGINT SIGTERM

# Check ports are free
if ss -tlnp 2>/dev/null | grep -q ':8092 '; then
    echo "FAIL: Port 8092 (llama.cpp) is already in use."
    echo "Stop the existing process or use a different port."
    exit 1
fi

if ss -tlnp 2>/dev/null | grep -q ':8088 '; then
    echo "FAIL: Port 8088 (Model Router) is already in use."
    echo "Stop the existing process or use a different port."
    exit 1
fi

# Check model file exists
if [[ ! -f "${OSAI_LLAMACPP_MODEL_PATH}" ]]; then
    echo "Missing GGUF model. Expected: ${OSAI_LLAMACPP_MODEL_PATH}"
    exit 1
fi

# Check venv exists
if [[ ! -d "$ROUTER_VENV" ]]; then
    echo "Model Router venv not found at: ${ROUTER_VENV}"
    echo "Run: cd services/model-router && python3 -m venv .venv && source .venv/bin/activate && pip install -e '.[dev]'"
    exit 1
fi

echo "=== Starting OSAI Local Runtime ==="
echo ""

# Start llama-server in background
echo "Starting llama-server..."
"${OSAI_LLAMACPP_BIN}" \
    -m "${OSAI_LLAMACPP_MODEL_PATH}" \
    -c "${OSAI_LLAMACPP_CTX_SIZE:-4096}" \
    -ngl "${OSAI_LLAMACPP_GPU_LAYERS:-999}" \
    --host 127.0.0.1 \
    --port 8092 \
    --api-key "${OSAI_LLAMACPP_API_KEY}" \
    ${OSAI_LLAMACPP_EXTRA_ARGS:-} \
    &
LLAMACPP_PID=$!

# Wait for llama.cpp to be ready
echo "Waiting for llama-server on port 8092..."
for i in {1..30}; do
    if curl -s --max-time 2 -o /dev/null http://127.0.0.1:8092/v1/models 2>/dev/null; then
        echo "llama-server is ready (PID $LLAMACPP_PID)"
        break
    fi
    if ! kill -0 "$LLAMACPP_PID" 2>/dev/null; then
        echo "llama-server exited unexpectedly. Check the model file and llama-server binary."
        exit 1
    fi
    sleep 1
done

if ! curl -s --max-time 2 -o /dev/null http://127.0.0.1:8092/v1/models 2>/dev/null; then
    echo "llama-server did not become ready in time."
    kill "$LLAMACPP_PID" 2>/dev/null || true
    exit 1
fi

echo ""

# Start Model Router in background
echo "Starting Model Router..."
cd "${REPO_ROOT}/services/model-router"
source "${ROUTER_VENV}/bin/activate"
export OSAI_LOCAL_PROVIDER="llamacpp"
export OSAI_LOCAL_MOCK="false"
export OSAI_LLAMACPP_BASE_URL="http://127.0.0.1:8092/v1"
export OSAI_LLAMACPP_MODEL="${OSAI_LLAMACPP_MODEL}"
export OSAI_LLAMACPP_API_KEY="${OSAI_LLAMACPP_API_KEY}"
export OSAI_MODEL_ROUTER_MOCK_CLOUD="true"

uvicorn osai_model_router.main:app --host 127.0.0.1 --port 8088 &
ROUTER_PID=$!

# Wait for Model Router to be ready
echo "Waiting for Model Router on port 8088..."
for i in {1..30}; do
    if curl -s --max-time 2 -o /dev/null http://127.0.0.1:8088/health 2>/dev/null; then
        echo "Model Router is ready (PID $ROUTER_PID)"
        break
    fi
    if ! kill -0 "$ROUTER_PID" 2>/dev/null; then
        echo "Model Router exited unexpectedly."
        kill "$LLAMACPP_PID" 2>/dev/null || true
        exit 1
    fi
    sleep 1
done

if ! curl -s --max-time 2 -o /dev/null http://127.0.0.1:8088/health 2>/dev/null; then
    echo "Model Router did not become ready in time."
    kill "$LLAMACPP_PID" "$ROUTER_PID" 2>/dev/null || true
    exit 1
fi

echo ""
echo "=== OSAI Local Runtime is running ==="
echo "llama-server PID:  $LLAMACPP_PID"
echo "Model Router PID:    $ROUTER_PID"
echo ""
echo "Press Ctrl+C to stop."

# Wait indefinitely (trap will clean up)
wait "$LLAMACPP_PID" "$ROUTER_PID" 2>/dev/null || true