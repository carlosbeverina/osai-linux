# OSAI Model Router Configuration
# Copy this file to .env and fill in values

# MiniMax API Key (required for real cloud requests)
MINIMAX_API_KEY=

# MiniMax API Base URL
MINIMAX_OPENAI_BASE_URL=https://api.minimax.io/v1

# Default MiniMax model
MINIMAX_MODEL=MiniMax-M2.7

# Fast model for speed-sensitive requests
MINIMAX_FAST_MODEL=MiniMax-M2.7-highspeed

# Mock cloud responses (true for testing/development)
OSAI_MODEL_ROUTER_MOCK_CLOUD=true

# Receipts directory (defaults to ~/.local/share/osai/receipts/model-router)
OSAI_RECEIPTS_DIR=

# =============================================================================
# Local Provider Configuration
# =============================================================================
# Local provider: "llamacpp" (default, laptop-optimized) or "vllm" (performance)
OSAI_LOCAL_PROVIDER=llamacpp

# Mock local responses (true for testing/development)
# Set to false to call real provider at *_BASE_URL
OSAI_LOCAL_MOCK=true

# =============================================================================
# llama.cpp Configuration (LAPTOP DEFAULT)
# =============================================================================
# llama.cpp provides excellent CPU/GPU support with quantized GGUF models.
# Recommended for laptops and resource-constrained environments.

# llama.cpp OpenAI-compatible base URL (must be loopback only)
OSAI_LLAMACPP_BASE_URL=http://127.0.0.1:8092/v1

# Default model served by llama.cpp (GGUF format)
OSAI_LLAMACPP_MODEL=gemma-local-gguf

# API key for llama.cpp (must match --api-key when starting llama-server)
OSAI_LLAMACPP_API_KEY=osai-local-dev-token

# =============================================================================
# vLLM Configuration (OPTIONAL PERFORMANCE BACKEND)
# =============================================================================
# vLLM provides excellent throughput for GPU-accelerated inference.
# Recommended for desktops with dedicated GPUs when llama.cpp is insufficient.

# vLLM OpenAI-compatible base URL (must be loopback only)
OSAI_VLLM_BASE_URL=http://127.0.0.1:8091/v1

# Default model served by vLLM
OSAI_VLLM_MODEL=gemma-local

# API key for vLLM (must match --api-key when starting vLLM)
OSAI_VLLM_API_KEY=osai-local-dev-token
