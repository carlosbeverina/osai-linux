# OSAI Model Router Configuration
# Copy this file to .env and fill in values

# MiniMax API Key (required for real cloud requests)
MINIMAX_API_KEY=

# MiniMax API Base URL
MINIMAX_OPENAI_BASE_URL=https://api.minimax.io/v1

# Default MiniMax model
MINIMAX_MODEL=MiniMax-M2.7

# Fast model for speed-sensitive requests
MINIMAX_FAST_MODEL=MiniMax-M2.7-highspeed

# Mock cloud responses (true for testing/development)
OSAI_MODEL_ROUTER_MOCK_CLOUD=true

# Receipts directory (defaults to ~/.local/share/osai/receipts/model-router)
OSAI_RECEIPTS_DIR=
