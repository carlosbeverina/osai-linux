# OSAI Model Router Configuration
# Copy this file to .env and fill in values

# MiniMax API Key (required for real cloud requests)
MINIMAX_API_KEY=

# MiniMax API Base URL
MINIMAX_OPENAI_BASE_URL=https://api.minimax.io/v1

# Default MiniMax model
MINIMAX_MODEL=MiniMax-M2.7

# Fast model for speed-sensitive requests
MINIMAX_FAST_MODEL=MiniMax-M2.7-highspeed

# Mock cloud responses (true for testing/development)
OSAI_MODEL_ROUTER_MOCK_CLOUD=true

# Receipts directory (defaults to ~/.local/share/osai/receipts/model-router)
OSAI_RECEIPTS_DIR=

# =============================================================================
# Local vLLM Configuration
# =============================================================================

# Local provider type (currently only vllm is supported)
OSAI_LOCAL_PROVIDER=vllm

# Mock local vLLM responses (true for testing/development)
# Set to false to call real vLLM server at OSAI_VLLM_BASE_URL
OSAI_LOCAL_MOCK=true

# vLLM OpenAI-compatible base URL (must be loopback only)
OSAI_VLLM_BASE_URL=http://127.0.0.1:8091/v1

# Default model served by vLLM
OSAI_VLLM_MODEL=gemma-local

# API key for vLLM (must match --api-key when starting vLLM)
OSAI_VLLM_API_KEY=osai-local-dev-token
